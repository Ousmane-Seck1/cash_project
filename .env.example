# =====================================================
# CASH - Configuration d'Environnement
# =====================================================
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS committer le fichier .env en production
# =====================================================

# ========== DJANGO ==========
# Secret key pour Django (utilisez: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=your-very-long-random-secret-key-here-change-this-in-production

# Mode debug (False en production)
DEBUG=True

# Domaines autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ========== BASE DE DONNÉES ==========
# Type de base de données : sqlite3, postgresql, mysql
DB_ENGINE=sqlite3
DB_NAME=db.sqlite3

# Pour PostgreSQL/MySQL, décommenter et remplir :
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=cash_db
# DB_USER=cash_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# ========== SÉCURITÉ ==========
# CORS - Origines autorisées pour les requêtes cross-origin
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Cookie settings
CSRF_COOKIE_SECURE=False  # True en production avec HTTPS
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=False  # True en production avec HTTPS
SESSION_COOKIE_HTTPONLY=True

# ========== EMAIL (pour notifications) ==========
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_DIR=logs

# ========== CACHE ==========
# CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache  # Développement
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache  # Production
# CACHE_LOCATION=redis://127.0.0.1:6379/1

# ========== AUTHENTIFICATION ==========
# Token expiration (en secondes)
TOKEN_EXPIRE_HOURS=24

# ========== HÔPITAL DÉFAUT ==========
# ID du centre de coûts par défaut
DEFAULT_CENTRE_COUT_ID=1

# ========== ENVIRONNEMENT ==========
ENVIRONMENT=development

# ========== API EXTERNE (si applicable) ==========
# API_KEY_EXTERNAL_SERVICE=your-api-key-here
# API_URL_EXTERNAL_SERVICE=https://api.example.com
